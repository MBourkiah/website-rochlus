---
/**
 * Dunkles Kontrast-Kapitel. Die Nummern bleiben hier bewusst: der Ablauf IST
 * eine Sequenz (frontend-design: Struktur nur, wo sie Information trägt).
 * Abschlusszeile senkt die Anruf-Hürde: Schritt 1 ist belegt unverbindlich.
 */
const schritte = [
  {
    titel: 'Besichtigung vor Ort',
    text: 'Wir kommen zu Ihnen, sehen uns Raum und Untergrund an und sagen Ihnen ehrlich, was geht — und was nicht.',
  },
  {
    titel: 'Planung & Beratung',
    text: 'Material, Format, Verlegebild und Budget legen wir gemeinsam fest. Sie entscheiden, wir beraten.',
  },
  {
    titel: 'Ausführung',
    text: 'Wir liefern das Material an und führen alle Arbeiten aus einer Hand aus — mit laufender Überwachung.',
  },
  {
    titel: 'Übergabe',
    text: 'Wir nehmen gemeinsam ab, bis zur letzten Fuge. Kleine Reparaturen übernehmen wir auch danach.',
  },
];
---

<section id="ablauf" class="kapitel-kontext scroll-mt-20 bg-kapitel text-kapitel-tinte">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-28">
    <p class="eyebrow text-kapitel-tinte-soft" data-reveal>So läuft Ihr Projekt</p>
    <h2 class="font-headline mt-5 max-w-2xl text-3xl leading-tight font-medium text-balance sm:text-5xl" data-reveal>
      Vier Schritte, <em class="italic">ein</em> Ansprechpartner.
    </h2>

    <!-- Terrakotta-Linie, die sich beim Erscheinen über alle Schritte zieht -->
    <div class="mt-16 h-0.5 bg-akzent" data-linie></div>

    <ol class="grid grid-cols-1 gap-10 pt-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8" data-reveal-gruppe>
      {
        schritte.map((s, i) => (
          <li data-reveal>
            <span class="font-headline text-5xl leading-none font-light text-kapitel-tinte-soft/60" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-headline mt-4 text-xl font-semibold">{s.titel}</h3>
            <p class="mt-2 text-sm leading-relaxed text-kapitel-tinte-soft">{s.text}</p>
          </li>
        ))
      }
    </ol>

    <!-- Die Hürde für Schritt 1 senken: Besichtigung ist laut Bestand unverbindlich -->
    <p class="mt-16 border-t border-kapitel-fuge pt-8 text-lg" data-reveal>
      <span class="text-kapitel-tinte-soft">Schritt 1 kostet Sie nichts als einen Anruf:</span>
      <a href="tel:+492219687575" class="font-headline ml-2 text-2xl font-semibold whitespace-nowrap transition-colors duration-150 hover:text-akzent-text">
        0221&nbsp;968&nbsp;75&nbsp;75
      </a>
    </p>
  </div>
</section>
