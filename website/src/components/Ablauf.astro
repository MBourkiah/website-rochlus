---
/**
 * Ablauf: die Beratungs-/Service-Punkte des Bestands (Besichtigung, Planung,
 * Überwachung) als Prozess erzählt — schafft Vertrauen statt Listenpunkte.
 * Nummerierte Zeile mit Fugen-Linie, kein Icon-Grid.
 */
const schritte = [
  {
    titel: 'Besichtigung vor Ort',
    text: 'Wir schauen uns Ihr Projekt bei Ihnen an — unverbindlich und mit ehrlicher Einschätzung.',
  },
  {
    titel: 'Planung & Beratung',
    text: 'Individuelle Planung: Material, Format, Verlegebild und Budget werden gemeinsam festgelegt.',
  },
  {
    titel: 'Ausführung',
    text: 'Materialanlieferung und Ausführung aus einer Hand — mit laufender Überwachung der Leistungen.',
  },
  {
    titel: 'Übergabe',
    text: 'Gemeinsame Abnahme bis zur letzten Fuge. Kleine Reparaturen übernehmen wir auch danach.',
  },
];
---

<section id="ablauf" class="scroll-mt-20 bg-flaeche">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <p class="eyebrow text-akzent-tief" data-reveal>So läuft Ihr Projekt</p>
    <h2 class="font-headline mt-4 max-w-2xl text-3xl leading-tight font-semibold text-balance sm:text-4xl" data-reveal>
      Vier Schritte, ein Ansprechpartner.
    </h2>

    <!-- Fugen-Linie, die sich beim Erscheinen über alle Schritte zieht -->
    <div class="mt-14 h-0.5 bg-akzent" data-linie></div>

    <ol class="grid grid-cols-1 gap-10 pt-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6" data-reveal-gruppe>
      {
        schritte.map((s, i) => (
          <li data-reveal>
            <span class="font-headline text-3xl font-light text-akzent-tief" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-3 text-base font-semibold">{s.titel}</h3>
            <p class="mt-2 text-sm leading-relaxed text-tinte-soft">{s.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
