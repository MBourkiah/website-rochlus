---
/**
 * Papier-Kapitel (heller Kontrastblock im editorialen Rhythmus).
 * Die Beratungs-/Service-Punkte des Bestands als Prozess erzählt.
 * Kupfer-Linie zieht sich beim Erscheinen über alle Schritte.
 */
const schritte = [
  {
    titel: 'Besichtigung vor Ort',
    text: 'Wir schauen uns Ihr Projekt bei Ihnen an — unverbindlich und mit ehrlicher Einschätzung.',
  },
  {
    titel: 'Planung & Beratung',
    text: 'Individuelle Planung: Material, Format, Verlegebild und Budget werden gemeinsam festgelegt.',
  },
  {
    titel: 'Ausführung',
    text: 'Materialanlieferung und Ausführung aus einer Hand — mit laufender Überwachung der Leistungen.',
  },
  {
    titel: 'Übergabe',
    text: 'Gemeinsame Abnahme bis zur letzten Fuge. Kleine Reparaturen übernehmen wir auch danach.',
  },
];
---

<section id="ablauf" class="papier-kontext scroll-mt-20 bg-papier text-papier-tinte">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-28">
    <p class="eyebrow text-papier-tinte-soft" data-reveal>So läuft Ihr Projekt</p>
    <h2 class="font-headline mt-5 max-w-2xl text-3xl leading-tight font-medium text-balance sm:text-5xl" data-reveal>
      Vier Schritte, <em class="italic">ein</em> Ansprechpartner.
    </h2>

    <!-- Kupfer-Linie, die sich beim Erscheinen über alle Schritte zieht -->
    <div class="mt-16 h-0.5 bg-akzent" data-linie></div>

    <ol class="grid grid-cols-1 gap-10 pt-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8" data-reveal-gruppe>
      {
        schritte.map((s, i) => (
          <li data-reveal>
            <span class="font-headline text-5xl leading-none font-light text-papier-tinte-soft/60" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-headline mt-4 text-xl font-semibold">{s.titel}</h3>
            <p class="mt-2 text-sm leading-relaxed text-papier-tinte-soft">{s.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
