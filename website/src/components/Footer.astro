---
/**
 * Footer: schlicht, Haarlinie, Rechtslinks. Bewusst ohne CMS-Werbezeile.
 * Bildmarke aus public/logo/icon-verband.svg — reine Formen, keine Texte,
 * daher unproblematisch als <img> (kein Font-Fallback-Risiko).
 */
const jahr = new Date().getFullYear();
---

<footer class="border-t border-fuge">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-8 text-sm text-tinte-soft sm:px-6">
    <p class="flex items-center gap-3">
      <img src="/logo/icon-verband.svg" alt="" width="18" height="18" class="opacity-80" aria-hidden="true" />
      © {jahr} Fliesenfachbetrieb Rochlus GmbH, Köln
    </p>
    <nav class="flex gap-6" aria-label="Rechtliches">
      <a href="/impressum" class="py-1 transition-colors duration-150 hover:text-tinte">Impressum</a>
      <a href="/datenschutz" class="py-1 transition-colors duration-150 hover:text-tinte">Datenschutz</a>
    </nav>
  </div>
</footer>
