---
/**
 * Sticky-Header mit Logo-Slot, Ankernavigation (mit Scrollspy) und Telefon-CTA.
 *
 * LOGO-SLOT: aktuell typografische Wortmarke als Interim.
 * Sobald die Logo-Entscheidung des Kunden vorliegt, hier tauschen:
 *   – bestehendes Mosaik-Logo: <img src="/bilder/logo-bestand.jpg" ...> (liegt in public/bilder/)
 *   – neues Logo: als SVG einsetzen
 * Der Slot ist höhenbegrenzt (h-10), beide Fälle passen ohne Layout-Änderung.
 */
const nav = [
  { href: '#leistungen', label: 'Leistungen' },
  { href: '#ablauf', label: 'Ablauf' },
  { href: '#betrieb', label: 'Der Betrieb' },
  { href: '#referenzen', label: 'Arbeiten' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<header
  id="hauptkopf"
  class="sticky top-0 z-40 border-b border-fuge bg-grund transition-shadow duration-150 data-gescrollt:shadow-[0_1px_0_var(--fuge),0_8px_24px_-16px_rgb(0_0_0/0.25)]"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <!-- Logo-Slot -->
    <a href="/" class="flex h-10 items-center gap-3" aria-label="Fliesenfachbetrieb Rochlus GmbH — zur Startseite">
      <span class="font-headline text-2xl font-semibold tracking-tight">Rochlus</span>
      <span class="hidden border-l border-fuge pl-3 text-[0.65rem] leading-tight font-semibold tracking-[0.18em] uppercase text-tinte-soft sm:block">
        Fliesenfachbetrieb<br />Köln
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Hauptnavigation">
      {nav.map((n) => (
        <a
          href={n.href}
          data-spy={n.href.slice(1)}
          class="group relative px-3 py-2.5 text-sm font-medium text-tinte-soft transition-colors duration-150 hover:text-tinte aria-[current]:text-tinte"
        >
          {n.label}
          <!-- animierte Fugen-Unterstreichung: wächst bei Hover/aktiver Section -->
          <span
            aria-hidden="true"
            class="absolute inset-x-3 bottom-1 h-0.5 origin-left scale-x-0 bg-akzent transition-transform duration-150 ease-out group-hover:scale-x-100 group-aria-[current]:scale-x-100"
          ></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="tel:+492219687575" class="knopf-primaer min-h-11! px-4! py-2!">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="hidden sm:inline">0221&nbsp;968&nbsp;75&nbsp;75</span>
        <span class="sm:hidden">Anrufen</span>
      </a>
      <!-- Mobile: Ankermenü ohne JavaScript -->
      <details class="relative md:hidden">
        <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center border border-fuge [&::-webkit-details-marker]:hidden" aria-label="Menü öffnen">
          <span aria-hidden="true" class="flex flex-col gap-1">
            <span class="block h-px w-4 bg-tinte"></span>
            <span class="block h-px w-4 bg-tinte"></span>
            <span class="block h-px w-4 bg-tinte"></span>
          </span>
        </summary>
        <nav class="absolute right-0 mt-2 flex w-52 flex-col border border-fuge bg-grund shadow-sm" aria-label="Mobile Navigation">
          {nav.map((n) => (
            <a href={n.href} class="border-b border-fuge px-4 py-3.5 text-sm font-medium last:border-b-0 hover:bg-flaeche">
              {n.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  // Mobile-Menü nach Ankerklick schließen
  document.querySelectorAll('details nav a').forEach((a) =>
    a.addEventListener('click', () => a.closest('details')?.removeAttribute('open'))
  );

  // Header wirft erst nach dem ersten Scroll einen Schatten (ruhiger Start)
  const kopf = document.getElementById('hauptkopf');
  const schattenSetzen = () => {
    if (window.scrollY > 8) kopf.setAttribute('data-gescrollt', '');
    else kopf.removeAttribute('data-gescrollt');
  };
  schattenSetzen();
  window.addEventListener('scroll', schattenSetzen, { passive: true });

  // Scrollspy: aktive Section in der Navigation markieren (aria-current)
  const spyLinks = new Map(
    [...document.querySelectorAll('[data-spy]')].map((a) => [a.getAttribute('data-spy'), a])
  );
  const spy = new IntersectionObserver(
    (eintraege) => {
      for (const e of eintraege) {
        const link = spyLinks.get(e.target.id);
        if (!link) continue;
        if (e.isIntersecting) {
          spyLinks.forEach((l) => l.removeAttribute('aria-current'));
          link.setAttribute('aria-current', 'true');
        }
      }
    },
    { rootMargin: '-30% 0px -60% 0px' }
  );
  spyLinks.forEach((_, id) => {
    const ziel = document.getElementById(id);
    if (ziel) spy.observe(ziel);
  });
</script>
