---
/**
 * Hero: bewusst asymmetrisch (Text links auf 7 Spalten, Fliesen-Komposition rechts
 * versetzt) — kein zentriertes Template-Hero. Das Fugenraster im Hintergrund ist
 * die Formensprache der Marke (Fliesenraster), kein Deko-Effekt.
 *
 * Motion-Konzept: Die Kacheln der Komposition erscheinen gestaffelt — wie
 * Fliesen, die eine nach der anderen gelegt werden. Bewegung erzählt das Gewerk.
 *
 * PLATZHALTER: Das Foto in der Kachel-Komposition stammt aus der alten collage.jpg
 * (600×420px) — wird ersetzt, sobald Originalfotos vom Kunden vorliegen.
 */
import PlatzhalterBadge from './PlatzhalterBadge.astro';
---

<section class="fugenraster relative overflow-hidden border-b border-fuge">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 pt-16 pb-14 sm:px-6 lg:grid-cols-12 lg:gap-6 lg:pt-24 lg:pb-20">
    <div class="lg:col-span-7" data-reveal-gruppe>
      <p class="eyebrow text-akzent-tief" data-reveal>Fliesenfachbetrieb Rochlus GmbH · Köln</p>
      <h1 class="font-headline mt-5 max-w-xl text-4xl leading-[1.05] font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl" data-reveal>
        Fliesen, Naturstein, komplette Bäder.
      </h1>
      <p class="mt-6 max-w-lg text-lg leading-relaxed text-tinte-soft" data-reveal>
        Vom ersten Aufmaß bis zur letzten Fuge: Wir planen, sanieren und verlegen —
        sorgfältig, termintreu und aus einer Hand. In Köln und Umgebung.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4" data-reveal>
        <a href="#kontakt" class="knopf-primaer">
          Projekt anfragen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="tel:+492219687575" class="knopf-sekundaer">
          Anruf: 0221&nbsp;968&nbsp;75&nbsp;75
        </a>
      </div>
      <!-- Vertrauens-Zeile direkt unter den CTAs (nur belegte Aussagen) -->
      <ul class="mt-8 flex max-w-lg flex-wrap gap-x-6 gap-y-2 text-sm text-tinte-soft" data-reveal>
        <li class="flex items-center gap-2">
          <span class="block h-2 w-2 bg-akzent" aria-hidden="true"></span>
          Besichtigung vor Ort, unverbindlich
        </li>
        <li class="flex items-center gap-2">
          <span class="block h-2 w-2 bg-akzent" aria-hidden="true"></span>
          Planung bis Übergabe aus einer Hand
        </li>
      </ul>
    </div>

    <!-- Fliesen-Komposition: Kacheln im Verband, gestaffelt „gelegt“;
         eine Kachel trägt das (Platzhalter-)Foto -->
    <div class="lg:col-span-5 lg:translate-y-8">
      <div class="grid max-w-md grid-cols-3 gap-1.5" data-reveal-gruppe>
        <div class="aspect-square bg-flaeche" data-reveal></div>
        <div class="aspect-square bg-akzent" data-reveal></div>
        <div class="aspect-square bg-dunkel" data-reveal></div>
        <div class="relative col-span-2 row-span-2 aspect-square" data-reveal>
          <img
            src="/bilder/platzhalter-verlegung-boden.jpg"
            alt="Fliesenleger bei der Verlegung von Bodenfliesen (Archivfoto in geringer Auflösung)"
            class="h-full w-full object-cover"
            width="210"
            height="195"
            fetchpriority="high"
          />
          <span class="absolute bottom-2 left-2">
            <PlatzhalterBadge text="Platzhalter — Originalfoto folgt" />
          </span>
        </div>
        <div class="aspect-square bg-mikro" data-reveal></div>
        <div class="aspect-square bg-flaeche" data-reveal></div>
      </div>
    </div>
  </div>
</section>
