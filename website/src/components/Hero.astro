---
/**
 * Hero, Dark Editorial: riesige Fraunces-Display-Zeile mit kursivem Akzentwort,
 * Glut-Schein oben rechts (der Ofen, aus dem die Fliese kommt), Fugenraster
 * als Haarlinien. Rechts eine dunkle Kachel-Komposition mit Kupfer-Akzenten,
 * die gestaffelt „gelegt" wird.
 *
 * PLATZHALTER: Das Foto stammt aus der alten collage.jpg (600×420px) —
 * wird ersetzt, sobald Originalfotos vom Kunden vorliegen.
 */
import PlatzhalterBadge from './PlatzhalterBadge.astro';
---

<section class="glut fugenraster relative overflow-hidden border-b border-fuge">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 px-4 pt-20 pb-16 sm:px-6 lg:grid-cols-12 lg:gap-6 lg:pt-32 lg:pb-28">
    <div class="lg:col-span-8" data-reveal-gruppe>
      <p class="eyebrow text-akzent-text" data-reveal>Fliesenfachbetrieb Rochlus GmbH · Köln</p>
      <h1
        class="font-headline mt-6 max-w-3xl text-[2.75rem] leading-[1.02] font-medium tracking-tight text-balance sm:text-6xl lg:text-7xl"
        data-reveal
      >
        Fliesen, Naturstein &amp; Bäder — <em class="text-akzent-text italic">aus einer Hand.</em>
      </h1>
      <p class="mt-8 max-w-md text-lg leading-relaxed text-tinte-soft" data-reveal>
        Vom ersten Aufmaß bis zur letzten Fuge: Wir planen, sanieren und
        verlegen — sorgfältig und termintreu. In Köln und Umgebung.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4" data-reveal>
        <a href="#kontakt" class="knopf-primaer">
          Projekt anfragen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="tel:+492219687575" class="knopf-sekundaer">
          0221&nbsp;968&nbsp;75&nbsp;75
        </a>
      </div>
      <ul class="mt-10 flex max-w-lg flex-wrap gap-x-8 gap-y-2 text-sm text-tinte-soft" data-reveal>
        <li class="flex items-center gap-2.5">
          <span class="block h-1.5 w-1.5 bg-akzent" aria-hidden="true"></span>
          Besichtigung vor Ort, unverbindlich
        </li>
        <li class="flex items-center gap-2.5">
          <span class="block h-1.5 w-1.5 bg-akzent" aria-hidden="true"></span>
          Planung bis Übergabe aus einer Hand
        </li>
      </ul>
    </div>

    <!-- Kachel-Komposition: dunkle Flächen + Kupfer, gestaffelt „gelegt" -->
    <div class="lg:col-span-4 lg:translate-y-10">
      <div class="grid max-w-sm grid-cols-3 gap-px" data-reveal-gruppe>
        <div class="aspect-square bg-flaeche" data-reveal></div>
        <div class="aspect-square bg-akzent" data-reveal></div>
        <div class="aspect-square border border-fuge" data-reveal></div>
        <div class="relative col-span-2 row-span-2 aspect-square" data-reveal>
          <img
            src="/bilder/platzhalter-verlegung-boden.jpg"
            alt="Fliesenleger bei der Verlegung von Bodenfliesen (Archivfoto in geringer Auflösung)"
            class="h-full w-full object-cover opacity-90"
            width="210"
            height="195"
            fetchpriority="high"
          />
          <span class="absolute bottom-2 left-2">
            <PlatzhalterBadge text="Platzhalter — Originalfoto folgt" />
          </span>
        </div>
        <div class="aspect-square bg-flaeche" data-reveal></div>
        <div class="aspect-square border border-fuge bg-grund" data-reveal></div>
      </div>
    </div>
  </div>
</section>
