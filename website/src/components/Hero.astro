---
/**
 * Hero „Typografisches Monument" (Hero-Centric-Muster: Vollbild, minimaler Text,
 * eine dominante CTA): Die Headline IST das Bild — drei gestaffelt einlaufende
 * Zeilen in Fraunces-Display mit Foto-Chips im Textfluss (editoriale Anmutung,
 * funktioniert auch mit den aktuellen Platzhalter-Fotos in geringer Auflösung).
 * Am Fuß zieht ein langsames Laufband mit allen Leistungen des Bestands vorbei.
 *
 * PLATZHALTER: Die Foto-Chips stammen aus der alten collage.jpg (600×420px) —
 * werden ersetzt, sobald Originalfotos vom Kunden vorliegen (Hinweiszeile unter CTA).
 */
const leistungen = [
  'Komplettsanierung inkl. Raumgestaltung',
  'Wand- und Bodenfliesen',
  'Naturstein',
  'Edle Materialien',
  'Elastische Fugen',
  'Trockenausbau',
  'Abdichtungsarbeiten',
  'Elektrische Fußbodenheizung',
  'Besichtigung vor Ort',
  'Individuelle Planung',
  'Materialanlieferung',
  'Reparaturarbeiten',
  'Überwachung der Leistungen',
];
---

<section class="glut fugenraster relative flex min-h-[calc(100dvh-4rem)] flex-col overflow-hidden border-b border-fuge">
  <div class="mx-auto flex w-full max-w-6xl flex-1 flex-col justify-center px-4 py-10 sm:px-6 lg:py-14" data-reveal-gruppe>
    <p class="eyebrow text-akzent-text" data-reveal>Fliesenfachbetrieb Rochlus GmbH · Köln</p>

    <!-- Das Monument: drei Zeilen, im Verband versetzt, Fotos im Textfluss -->
    <h1 class="font-headline mt-7 text-[clamp(2.9rem,8.5vw,6.5rem)] leading-[0.98] font-medium tracking-tight">
      <span class="block" data-reveal>
        Fliesen<span class="text-akzent">.</span>
        <img
          src="/bilder/platzhalter-klebebett.jpg"
          alt="Klebebett wird mit der Zahnkelle aufgezogen (Archivfoto, Platzhalter)"
          class="hero-chip"
          width="155"
          height="140"
          fetchpriority="high"
        />
      </span>
      <span class="block pl-[0.8em]" data-reveal>Naturstein<span class="text-akzent">.</span></span>
      <span class="block" data-reveal>
        <img
          src="/bilder/platzhalter-verlegung-boden.jpg"
          alt="Verlegung großformatiger Bodenfliesen (Archivfoto, Platzhalter)"
          class="hero-chip"
          width="210"
          height="195"
        />
        Bäder <em class="text-akzent-text italic">— die bleiben.</em>
      </span>
    </h1>

    <div class="mt-10 flex flex-wrap items-end justify-between gap-8" data-reveal>
      <p class="max-w-sm text-base leading-relaxed text-tinte-soft sm:text-lg">
        Vom ersten Aufmaß bis zur letzten Fuge — geplant, saniert und verlegt
        aus einer Hand. In Köln und Umgebung.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href="#kontakt" class="knopf-primaer px-8! py-4! text-base!">
          Projekt anfragen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="tel:+492219687575"
          class="py-2 text-sm font-semibold text-tinte-soft underline decoration-fuge underline-offset-8 transition-colors duration-150 hover:text-tinte hover:decoration-akzent"
        >
          oder anrufen: 0221&nbsp;968&nbsp;75&nbsp;75
        </a>
      </div>
    </div>
    <p class="mt-6 text-xs tracking-wide text-tinte-soft/70" data-reveal>
      Fotos: Archiv-Platzhalter in geringer Auflösung — Originale folgen vom Kunden.
    </p>
  </div>

  <!-- Laufband: alle Leistungen des Bestands, langsam ziehend -->
  <div class="laufband-huelle relative border-t border-fuge py-5" aria-label="Unsere Leistungen im Überblick">
    <div class="laufband">
      {
        [false, true].map((istKopie) => (
          <ul class="flex shrink-0 items-center" aria-hidden={istKopie ? 'true' : undefined}>
            {leistungen.map((l) => (
              <li class="flex items-center gap-6 pr-6 text-sm font-medium tracking-wide whitespace-nowrap text-tinte-soft">
                {l}
                <span class="block h-2 w-2 bg-akzent" aria-hidden="true" />
              </li>
            ))}
          </ul>
        ))
      }
    </div>
  </div>
</section>
