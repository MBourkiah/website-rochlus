---
/**
 * Kontakt-Finale: die Telefonnummer als größtes Element der Seite in Fraunces —
 * der Hauptkanal eines Handwerksbetriebs. Glut-Schein als Wiederaufnahme des Heros.
 * Alle Daten aus dem Bestand übernommen (belegt).
 * Erreichbarkeitszeiten: Platzhalter — vom Kunden.
 */
import PlatzhalterBadge from './PlatzhalterBadge.astro';
---

<section id="kontakt" class="glut scroll-mt-20 border-t border-fuge">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 px-4 py-20 sm:px-6 lg:grid-cols-12 lg:py-32">
    <div class="lg:col-span-8" data-reveal-gruppe>
      <p class="eyebrow text-akzent-text" data-reveal>Kontakt</p>
      <h2 class="font-headline mt-5 max-w-xl text-3xl leading-tight font-medium text-balance sm:text-5xl" data-reveal>
        Erzählen Sie uns von <em class="italic">Ihrem Projekt.</em>
      </h2>
      <p class="mt-6 max-w-md leading-relaxed text-tinte-soft" data-reveal>
        Am schnellsten geht es telefonisch — oder Sie schreiben eine E-Mail mit ein
        paar Eckdaten, wir melden uns zurück.
      </p>

      <a
        href="tel:+492219687575"
        class="group font-headline mt-12 inline-block text-5xl font-medium tracking-tight transition-colors duration-150 hover:text-akzent-text sm:text-7xl"
        data-reveal
      >
        0221&nbsp;968&nbsp;75&nbsp;75
        <span aria-hidden="true" class="mt-3 block h-0.5 w-full origin-left scale-x-0 bg-akzent transition-transform duration-150 ease-out group-hover:scale-x-100"></span>
      </a>
      <div class="mt-6 flex flex-wrap gap-x-8 gap-y-2 text-sm text-tinte-soft" data-reveal>
        <a href="tel:+491722770674" class="transition-colors duration-150 hover:text-tinte">Mobil: 0172&nbsp;277&nbsp;06&nbsp;74</a>
        <a href="mailto:mrochlus@web.de" class="underline underline-offset-4 transition-colors duration-150 hover:text-tinte">
          mrochlus@web.de
        </a>
      </div>
    </div>

    <div class="border-t border-fuge pt-8 text-sm leading-relaxed lg:col-span-4 lg:col-start-9 lg:border-t-0 lg:border-l lg:pt-0 lg:pl-10">
      <p class="font-headline text-lg font-semibold">Fliesenfachbetrieb Rochlus GmbH</p>
      <p class="mt-2 text-tinte-soft">
        Kranzbinderweg 15<br />
        51067 Köln
      </p>
      <p class="mt-8 text-xs font-semibold tracking-widest uppercase text-tinte-soft">Erreichbarkeit</p>
      <p class="mt-2">
        <PlatzhalterBadge text="Zeiten folgen vom Kunden" />
      </p>
      <p class="mt-8 text-xs font-semibold tracking-widest uppercase text-tinte-soft">Einzugsgebiet</p>
      <p class="mt-2 text-tinte-soft">Köln und Umgebung</p>
    </div>
  </div>
</section>
