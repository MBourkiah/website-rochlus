---
/**
 * Leistungen als editorialer Index: große Zeilen wie ein Inhaltsverzeichnis,
 * Haarlinien als Fugen, riesige Serifen-Nummern. Kein Karten-Grid.
 * Alle 13 Punkte des Bestands bleiben erhalten, gruppiert und priorisiert
 * (Komplettsanierung hat als 01 die eigene Kupfer-Section davor).
 */
const gruppen = [
  {
    nr: '02',
    titel: 'Verlegearbeiten',
    text: 'Das Kernhandwerk: präzise Verlegung auf Wand und Boden — vom klassischen Fliesenspiegel bis zum großformatigen Naturstein.',
    punkte: ['Wand- und Bodenfliesen', 'Naturstein', 'Verarbeitung edler Materialien', 'Elastische Fugen'],
  },
  {
    nr: '03',
    titel: 'Sanierung & Ausbau',
    text: 'Was vor und nach der Fliese kommt: trockener Ausbau, sichere Abdichtung, schnelle Reparatur.',
    punkte: ['Trockenausbau', 'Abdichtungsarbeiten', 'Ausführung kleiner Reparaturarbeiten'],
  },
  {
    nr: '04',
    titel: 'Technik & Service',
    text: 'Komfort unter der Oberfläche und Service drumherum.',
    punkte: ['Einbau elektrischer Fußbodenheizungen', 'Materialanlieferung', 'Besichtigung und Beratung vor Ort'],
  },
];
---

<section id="leistungen" class="scroll-mt-20 border-b border-fuge">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-28">
    <p class="eyebrow text-akzent-text" data-reveal>Leistungen</p>
    <h2 class="font-headline mt-5 max-w-2xl text-3xl leading-tight font-medium text-balance sm:text-5xl" data-reveal>
      Alles rund um die Fliese — und das, was dazugehört.
    </h2>

    <div class="mt-16" data-reveal-gruppe>
      {
        gruppen.map((g) => (
          <div class="index-zeile grid grid-cols-1 gap-6 border-t border-fuge px-2 py-10 last:border-b sm:px-4 lg:grid-cols-12 lg:items-start" data-reveal>
            <span class="font-headline text-6xl leading-none font-light text-tinte-soft/50 lg:col-span-2" aria-hidden="true">
              {g.nr}
            </span>
            <div class="lg:col-span-4">
              <h3 class="font-headline text-2xl font-semibold sm:text-3xl">{g.titel}</h3>
              <p class="mt-3 max-w-sm text-sm leading-relaxed text-tinte-soft">{g.text}</p>
            </div>
            <ul class="space-y-2.5 text-sm lg:col-span-5">
              {g.punkte.map((p) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-akzent" aria-hidden="true" />
                  {p}
                </li>
              ))}
            </ul>
            <span class="index-pfeil hidden text-tinte-soft lg:col-span-1 lg:block lg:justify-self-end" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
