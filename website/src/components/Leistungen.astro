---
/**
 * Leistungen: die 13 Punkte des Bestands, neu gruppiert und priorisiert
 * (Komplettsanierung hat als 01 eine eigene Section davor).
 * Bewusst KEINE drei identischen Icon-Karten: ungleich breite Blöcke im
 * Verband-Versatz, typografische Nummerierung statt Icons.
 */
const gruppen = [
  {
    nr: '02',
    titel: 'Verlegearbeiten',
    text: 'Das Kernhandwerk: präzise Verlegung auf Wand und Boden — vom klassischen Fliesenspiegel bis zum großformatigen Naturstein.',
    punkte: [
      'Wand- und Bodenfliesen',
      'Naturstein',
      'Verarbeitung edler Materialien',
      'Elastische Fugen',
    ],
    breite: 'lg:col-span-7',
  },
  {
    nr: '03',
    titel: 'Sanierung & Ausbau',
    text: 'Was vor und nach der Fliese kommt: trockener Ausbau, sichere Abdichtung, schnelle Reparatur.',
    punkte: [
      'Trockenausbau',
      'Abdichtungsarbeiten',
      'Ausführung kleiner Reparaturarbeiten',
    ],
    breite: 'lg:col-span-5 lg:translate-y-10',
  },
  {
    nr: '04',
    titel: 'Technik & Service',
    text: 'Komfort unter der Oberfläche und Service drumherum.',
    punkte: [
      'Einbau elektrischer Fußbodenheizungen',
      'Materialanlieferung',
      'Besichtigung und Beratung vor Ort',
    ],
    breite: 'lg:col-span-5 lg:col-start-2',
  },
];
---

<section id="leistungen" class="scroll-mt-20 border-b border-fuge">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <p class="eyebrow text-akzent-tief" data-reveal>Leistungen</p>
    <h2 class="font-headline mt-4 max-w-2xl text-3xl leading-tight font-semibold text-balance sm:text-4xl" data-reveal>
      Alles rund um die Fliese — und das, was dazugehört.
    </h2>

    <div class="mt-14 grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-x-6 lg:gap-y-16 lg:pb-10" data-reveal-gruppe>
      {
        gruppen.map((g) => (
          <div
            class={`group border-t-2 border-tinte pt-6 transition-colors duration-150 ${g.breite}`}
            data-reveal
          >
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-headline text-2xl font-semibold">{g.titel}</h3>
              <span
                class="font-headline text-4xl font-light text-mikro transition-colors duration-150 group-hover:text-akzent"
                aria-hidden="true"
              >
                {g.nr}
              </span>
            </div>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-tinte-soft">{g.text}</p>
            <ul class="mt-5 space-y-2 text-sm">
              {g.punkte.map((p) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 block h-2 w-2 shrink-0 bg-akzent" aria-hidden="true"></span>
                  {p}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
