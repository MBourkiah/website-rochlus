---
/**
 * SIGNATURE-ELEMENT „Verlegeplan": Die Leistungen liegen als Fliesen in
 * ungleichen Formaten im Verband — der Grid-Zwischenraum ist eine echte Fuge
 * (Container zeigt Fugenfarbe durch den Gap). Die Formatgröße kodiert die
 * Gewichtung der Leistungsgruppe (Kernhandwerk = größtes Format).
 * Bewusst OHNE Nummerierung: Leistungen sind keine Sequenz (frontend-design:
 * Struktur muss Information tragen). Eine Terrakotta-Fliese im Verband ist
 * die CTA für alle, die ihr Projekt nicht zuordnen können.
 * Alle 13 Punkte des Bestands bleiben erhalten.
 */
const kacheln = [
  {
    label: 'Das Kernhandwerk',
    titel: 'Verlegearbeiten',
    text: 'Präzise Verlegung auf Wand und Boden — vom klassischen Fliesenspiegel bis zum großformatigen Naturstein.',
    punkte: ['Wand- und Bodenfliesen', 'Naturstein', 'Verarbeitung edler Materialien', 'Elastische Fugen'],
    klasse: 'lg:col-span-7',
  },
  {
    label: 'Vor und nach der Fliese',
    titel: 'Sanierung & Ausbau',
    text: 'Trockener Ausbau, sichere Abdichtung, schnelle Reparatur — damit der Untergrund so gut ist wie die Oberfläche.',
    punkte: ['Trockenausbau', 'Abdichtungsarbeiten', 'Kleine Reparaturarbeiten'],
    klasse: 'lg:col-span-5',
  },
  {
    label: 'Komfort & Service',
    titel: 'Technik & Service',
    text: 'Warme Füße und kurze Wege: Technik unter der Oberfläche, Service drumherum.',
    punkte: ['Elektrische Fußbodenheizungen', 'Materialanlieferung', 'Besichtigung und Beratung vor Ort'],
    klasse: 'lg:col-span-5 lg:col-start-2',
  },
];
---

<section id="leistungen" class="scroll-mt-20">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-28">
    <p class="eyebrow text-akzent-text" data-reveal>Leistungen</p>
    <h2 class="font-headline mt-5 max-w-2xl text-3xl leading-tight font-medium text-balance sm:text-5xl" data-reveal>
      Alles rund um die Fliese — und das, was dazugehört.
    </h2>

    <!-- Der Verlegeplan: gap-1.5 auf Fugenfarbe = echte Fuge zwischen den Formaten -->
    <div class="mt-16 grid grid-cols-1 gap-1.5 border border-fuge bg-fuge p-1.5 lg:grid-cols-12" data-reveal-gruppe>
      {
        kacheln.map((k) => (
          <div class={`bg-grund p-7 transition-colors duration-150 hover:bg-flaeche sm:p-9 ${k.klasse}`} data-reveal>
            <p class="text-xs font-semibold tracking-widest uppercase text-tinte-soft">{k.label}</p>
            <h3 class="font-headline mt-3 text-2xl font-semibold sm:text-3xl">{k.titel}</h3>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-tinte-soft">{k.text}</p>
            <ul class="mt-6 space-y-2.5 text-sm">
              {k.punkte.map((p) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 bg-akzent" aria-hidden="true" />
                  {p}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <!-- Die CTA-Fliese im Verband -->
      <a
        href="#kontakt"
        class="group flex flex-col justify-between bg-akzent p-7 text-akzent-kontrast transition-colors duration-150 hover:bg-akzent-hover sm:p-9 lg:col-span-5"
        data-reveal
      >
        <p class="font-headline text-2xl leading-snug font-semibold text-balance sm:text-3xl">
          Nicht sicher, was Ihr Projekt braucht?
        </p>
        <p class="mt-6 flex items-center gap-2 text-sm font-semibold">
          Wir schauen es uns an — unverbindlich
          <svg class="transition-transform duration-150 group-hover:translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </p>
      </a>
    </div>
  </div>
</section>
