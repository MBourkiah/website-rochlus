---
/**
 * Conversion-Element: feste Aktionsleiste am unteren Rand (nur Mobile).
 * Der Hauptkanal eines Handwerksbetriebs ist das Telefon — der Anruf-Button
 * ist damit auf Mobilgeräten immer einen Daumen entfernt.
 * Safe-Area (Gesten-Balken) wird berücksichtigt; der Seiteninhalt bekommt
 * in index.astro entsprechendes Bottom-Padding, damit nichts verdeckt wird.
 */
---

<div
  class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 border-t border-fuge bg-grund pb-[env(safe-area-inset-bottom)] md:hidden"
>
  <a
    href="tel:+492219687575"
    class="flex min-h-14 items-center justify-center gap-2 bg-akzent text-sm font-semibold text-akzent-kontrast active:scale-[0.98]"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    Jetzt anrufen
  </a>
  <a
    href="#kontakt"
    class="flex min-h-14 items-center justify-center gap-2 text-sm font-semibold active:scale-[0.98]"
  >
    Anfrage senden
  </a>
</div>
