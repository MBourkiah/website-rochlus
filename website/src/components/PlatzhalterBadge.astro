---
/**
 * Kennzeichnet Inhalte, die noch vom Kunden kommen müssen.
 * Jede Verwendung entspricht einem Punkt auf der Kunden-Checkliste (siehe konzept/).
 */
interface Props {
  text?: string;
}
const { text = 'Platzhalter' } = Astro.props;
---

<!-- bg-grund macht das Badge auch auf dunklen Flächen und Fotos lesbar -->
<span
  class="inline-flex items-center gap-1.5 border border-dashed border-akzent bg-grund px-2 py-0.5 text-[0.65rem] font-semibold tracking-widest uppercase text-akzent-tief"
>
  {text}
</span>
