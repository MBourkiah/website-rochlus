---
/**
 * Kennzeichnet Inhalte, die noch vom Kunden kommen müssen.
 * Dunkler Chip mit Kupfer-Text — lesbar auf dunklen Flächen, Papier und Fotos.
 * Jede Verwendung entspricht einem Punkt auf der Kunden-Checkliste (siehe konzept/).
 */
interface Props {
  text?: string;
}
const { text = 'Platzhalter' } = Astro.props;
---

<span
  class="inline-flex items-center gap-1.5 border border-dashed border-akzent bg-grund px-2 py-0.5 text-[0.65rem] font-semibold tracking-widest uppercase text-akzent-text"
>
  {text}
</span>
