---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Komplettsanierung from '../components/Komplettsanierung.astro';
import Leistungen from '../components/Leistungen.astro';
import Ablauf from '../components/Ablauf.astro';
import Betrieb from '../components/Betrieb.astro';
import Referenzen from '../components/Referenzen.astro';
import Kontakt from '../components/Kontakt.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
---

<Base
  title="Fliesenfachbetrieb Rochlus GmbH — Fliesen, Naturstein & Komplettsanierung in Köln"
  description="Fliesenfachbetrieb in Köln: Verlegung von Fliesen und Naturstein, Komplettsanierung inkl. Raumgestaltung, Abdichtung und elektrische Fußbodenheizung. Beratung vor Ort."
>
  <Header />
  <!-- pb: Platz für die mobile Call-Bar, damit sie keinen Inhalt verdeckt -->
  <div class="pb-14 md:pb-0">
    <main id="inhalt">
      <Hero />
      <Komplettsanierung />
      <Leistungen />
      <Ablauf />
      <Betrieb />
      <Referenzen />
      <Kontakt />
    </main>
    <Footer />
  </div>
  <MobileCallBar />
</Base>
